<?xml version="1.0" encoding="UTF-8"?>
<Module>
  <ModulePrefs title="DNG - First 10 Requirements in Module"
               description="Shows the first ten requirements from a configured DOORS Next module."
               author="M365 Copilot"
               scrolling="true"
               height="460">
    <Require feature="dynamic-height" />
    <Require feature="setprefs" />
  </ModulePrefs>

  <!-- Defaults are set for your project/module. Adjust RM Base URL and configuration if needed after adding the widget. -->
  <UserPref name="rmBaseUrl" display_name="RM Base URL" default_value="" datatype="string" />
  <UserPref name="projectAreaName" display_name="Project area name" default_value="709046-Tramcité Contrat Système (Requirements)" datatype="string" />
  <UserPref name="moduleTitle" display_name="Module title" default_value="580690CS - Annexe 5 Partie 10" datatype="string" />
  <UserPref name="moduleUri" display_name="Optional module resource URI" default_value="" datatype="string" />
  <UserPref name="configurationUri" display_name="Optional configuration URI / stream URL" default_value="" datatype="string" />

  <Content type="html"><![CDATA[
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<style>
  body { font-family: Arial, Helvetica, sans-serif; margin: 0; padding: 12px; color: #1f2933; background: #ffffff; }
  .header { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 10px; }
  h2 { font-size: 16px; margin: 0 0 4px 0; color: #111827; }
  .meta { font-size: 12px; color: #4b5563; line-height: 1.35; }
  button { border: 1px solid #1f6feb; background: #1f6feb; color: white; padding: 6px 10px; border-radius: 4px; cursor: pointer; font-size: 12px; }
  button:hover { background: #1558bd; }
  .status { margin: 10px 0; padding: 8px 10px; border-radius: 4px; font-size: 12px; background: #eef2ff; color: #1e3a8a; }
  .error { background: #fee2e2; color: #991b1b; white-space: pre-wrap; }
  table { width: 100%; border-collapse: collapse; table-layout: fixed; margin-top: 8px; }
  th { background: #f3f4f6; color: #111827; text-align: left; font-weight: 600; border: 1px solid #d1d5db; padding: 7px; font-size: 12px; }
  td { border: 1px solid #d1d5db; padding: 7px; vertical-align: top; font-size: 12px; word-wrap: break-word; overflow-wrap: anywhere; }
  .col-num { width: 42px; text-align: right; color: #374151; }
  .col-id { width: 95px; }
  .title { font-weight: 600; color: #111827; }
  .text { margin-top: 4px; color: #374151; line-height: 1.35; max-height: 7.2em; overflow: hidden; }
  a { color: #1f6feb; text-decoration: none; }
  a:hover { text-decoration: underline; }
  .hint { font-size: 11px; color: #6b7280; margin-top: 8px; }
</style>
<script type="text/javascript">
(function () {
  "use strict";

  var MAX_REQUIREMENTS = 10;
  var prefs;

  function byId(id) { return document.getElementById(id); }
  function esc(s) {
    return String(s || "").replace(/[&<>"']/g, function(c) {
      return {"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"}[c];
    });
  }
  function stripHtml(s) {
    var div = document.createElement("div");
    div.innerHTML = s || "";
    return (div.textContent || div.innerText || "").replace(/\s+/g, " ").trim();
  }
  function setStatus(msg, isError) {
    var el = byId("status");
    el.className = isError ? "status error" : "status";
    el.textContent = msg;
    el.style.display = msg ? "block" : "none";
    adjustHeight();
  }
  function adjustHeight() {
    try { gadgets.window.adjustHeight(); } catch (e) { /* ignore outside OpenSocial */ }
  }

  function getPref(name) {
    try { return prefs.getString(name) || ""; } catch (e) { return ""; }
  }

  function detectRmBaseUrl() {
    var configured = getPref("rmBaseUrl").trim().replace(/\/$/, "");
    if (configured) return configured;
    var origin = window.location.protocol + "//" + window.location.host;
    return origin + "/rm";
  }

  function appendConfiguration(url) {
    var cfg = getPref("configurationUri").trim();
    if (!cfg) return url;
    var sep = url.indexOf("?") >= 0 ? "&" : "?";
    return url + sep + "oslc_config.context=" + encodeURIComponent(cfg);
  }

  function requestText(url) {
    return new Promise(function(resolve, reject) {
      // Primary path: authenticated same-origin call from the DOORS Next dashboard/widget container.
      fetch(url, {
        method: "GET",
        credentials: "include",
        headers: {
          "Accept": "application/rdf+xml, application/xml, text/xml, */*",
          "OSLC-Core-Version": "2.0"
        }
      }).then(function(resp) {
        if (!resp.ok) throw new Error("HTTP " + resp.status + " " + resp.statusText + " for " + url);
        return resp.text();
      }).then(resolve).catch(function(fetchError) {
        // Fallback path for OpenSocial containers where fetch is restricted.
        if (typeof gadgets !== "undefined" && gadgets.io && gadgets.io.makeRequest) {
          var params = {};
          params[gadgets.io.RequestParameters.METHOD] = gadgets.io.MethodType.GET;
          params[gadgets.io.RequestParameters.CONTENT_TYPE] = gadgets.io.ContentType.TEXT;
          params[gadgets.io.RequestParameters.HEADERS] = {
            "Accept": "application/rdf+xml, application/xml, text/xml, */*",
            "OSLC-Core-Version": "2.0"
          };
          gadgets.io.makeRequest(url, function(response) {
            if (response.errors && response.errors.length) {
              reject(new Error(response.errors.join("\n")));
              return;
            }
            if (response.rc && response.rc >= 400) {
              reject(new Error("HTTP " + response.rc + " for " + url));
              return;
            }
            resolve(response.text || response.data || "");
          }, params);
        } else {
          reject(fetchError);
        }
      });
    });
  }

  function parseXml(text) {
    var parser = new DOMParser();
    var xml = parser.parseFromString(text, "application/xml");
    if (xml.getElementsByTagName("parsererror").length) {
      throw new Error("The server response could not be parsed as XML.");
    }
    return xml;
  }

  function attrAnyNs(node, localName) {
    if (!node || !node.attributes) return "";
    for (var i = 0; i < node.attributes.length; i++) {
      if (node.attributes[i].localName === localName) return node.attributes[i].value;
    }
    return "";
  }

  function firstTextByLocalName(root, localName) {
    var nodes = root.getElementsByTagName("*");
    for (var i = 0; i < nodes.length; i++) {
      if (nodes[i].localName === localName && nodes[i].textContent) return nodes[i].textContent.trim();
    }
    return "";
  }

  function findRequirementLinksFromModuleXml(xml) {
    var links = [];
    var nodes = xml.getElementsByTagName("*");
    for (var i = 0; i < nodes.length; i++) {
      if (nodes[i].localName === "uses") {
        var uri = attrAnyNs(nodes[i], "resource");
        if (uri && links.indexOf(uri) < 0) links.push(uri);
      }
    }
    return links.slice(0, MAX_REQUIREMENTS);
  }

  function buildModuleQueryUrl(baseUrl) {
    var moduleUri = getPref("moduleUri").trim();
    if (moduleUri) return appendConfiguration(moduleUri);

    var title = getPref("moduleTitle").trim();
    var prefix = "dcterms=<http://purl.org/dc/terms/>,oslc_rm=<http://open-services.net/ns/rm#>";
    var select = "dcterms:identifier,dcterms:title,oslc_rm:uses{dcterms:identifier,dcterms:title}";
    var where = "dcterms:title=\"" + title.replace(/\\/g, "\\\\").replace(/\"/g, "\\\"") + "\"";
    var url = baseUrl + "/views?oslc.query=true" +
      "&oslc.prefix=" + encodeURIComponent(prefix) +
      "&oslc.select=" + encodeURIComponent(select) +
      "&oslc.where=" + encodeURIComponent(where);
    return appendConfiguration(url);
  }

  function normalizeResourceUrl(uri, baseUrl) {
    if (/^https?:\/\//i.test(uri)) return appendConfiguration(uri);
    return appendConfiguration(baseUrl.replace(/\/$/, "") + uri);
  }

  function readRequirement(uri, index, baseUrl) {
    return requestText(normalizeResourceUrl(uri, baseUrl)).then(function(text) {
      var xml = parseXml(text);
      return {
        n: index + 1,
        uri: uri,
        identifier: firstTextByLocalName(xml, "identifier") || "",
        title: firstTextByLocalName(xml, "title") || "Untitled requirement",
        primaryText: firstTextByLocalName(xml, "primaryText") || firstTextByLocalName(xml, "description") || ""
      };
    }).catch(function(err) {
      return { n: index + 1, uri: uri, identifier: "", title: "Unable to read requirement", primaryText: err.message };
    });
  }

  function renderRows(items) {
    var tbody = byId("reqRows");
    tbody.innerHTML = "";
    items.forEach(function(item) {
      var tr = document.createElement("tr");
      tr.innerHTML =
        "<td class='col-num'>" + item.n + "</td>" +
        "<td class='col-id'>" + esc(item.identifier) + "</td>" +
        "<td><div class='title'><a target='_blank' rel='noopener noreferrer' href='" + esc(item.uri) + "'>" + esc(item.title) + "</a></div>" +
        "<div class='text'>" + esc(stripHtml(item.primaryText)) + "</div></td>";
      tbody.appendChild(tr);
    });
    byId("resultTable").style.display = items.length ? "table" : "none";
    adjustHeight();
  }

  function loadRequirements() {
    prefs = new gadgets.Prefs();
    var baseUrl = detectRmBaseUrl();
    var project = getPref("projectAreaName");
    var moduleTitle = getPref("moduleTitle");

    byId("projectName").textContent = project;
    byId("moduleName").textContent = moduleTitle;
    byId("baseUrl").textContent = baseUrl;
    byId("resultTable").style.display = "none";
    byId("reqRows").innerHTML = "";

    setStatus("Loading module and first ten requirements...", false);

    requestText(buildModuleQueryUrl(baseUrl))
      .then(function(text) {
        var xml = parseXml(text);
        var links = findRequirementLinksFromModuleXml(xml);
        if (!links.length) {
          throw new Error("No requirements were found in the module response. If this project uses configuration management, set the configuration URI/stream URL in the widget preferences. If more than one module has the same title, set the optional module resource URI.");
        }
        setStatus("Found " + links.length + " requirement link(s). Loading details...", false);
        return Promise.all(links.map(function(uri, idx) { return readRequirement(uri, idx, baseUrl); }));
      })
      .then(function(items) {
        renderRows(items);
        setStatus("Showing the first " + items.length + " requirement(s) returned for this module.", false);
      })
      .catch(function(err) {
        renderRows([]);
        setStatus("Unable to load requirements.\n\n" + err.message + "\n\nChecks:\n1. You are logged in to DOORS Next.\n2. RM Base URL is correct, for example https://server/rm.\n3. If configuration management is enabled, set the configuration URI/stream URL.\n4. If the module title is not unique, paste the module resource URI in widget preferences.", true);
      });
  }

  window.onload = loadRequirements;
  window.loadRequirements = loadRequirements;
}());
</script>
</head>
<body>
  <div class="header">
    <div>
      <h2>First 10 requirements in module</h2>
      <div class="meta"><strong>Project area:</strong> <span id="projectName"></span></div>
      <div class="meta"><strong>Module:</strong> <span id="moduleName"></span></div>
      <div class="meta"><strong>RM base URL:</strong> <span id="baseUrl"></span></div>
    </div>
    <button onclick="loadRequirements()">Refresh</button>
  </div>

  <div id="status" class="status" style="display:none"></div>

  <table id="resultTable" style="display:none">
    <thead>
      <tr>
        <th class="col-num">#</th>
        <th class="col-id">ID</th>
        <th>Requirement</th>
      </tr>
    </thead>
    <tbody id="reqRows"></tbody>
  </table>

  <div class="hint">
    Tip: configure the widget preferences if your RM server is not detected automatically or if the module is in a specific stream/configuration.
  </div>
</body>
</html>
  ]]></Content>
</Module>
