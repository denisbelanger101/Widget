<?xml version="1.0" encoding="UTF-8"?>
<Module>
  <ModulePrefs
      title="DNG - 10 premieres exigences du module"
      description="Affiche les dix premieres exigences d'un module DOORS Next 7.0.3 a partir de son URL directe."
      author="M365 Copilot"
      scrolling="true"
      height="520">
    <Require feature="dynamic-height" />
    <Require feature="setprefs" />
  </ModulePrefs>

  <UserPref name="moduleUrl"
            display_name="URL directe du module"
            datatype="string"
            default_value="https://atkinsrealis.clm.ibmcloud.com/rm/resources/MD__lBuQHyDEfGNOpnLr1I6dA?oslc_config.context=https://atkinsrealis.clm.ibmcloud.com/rm/cm/stream/_-szKBkrkEfGjQZaMomm1sg" />

  <UserPref name="maxItems"
            display_name="Nombre maximal d'exigences"
            datatype="string"
            default_value="10" />

  <Content type="html"><![CDATA[
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<style>
  body { font-family: Arial, Helvetica, sans-serif; margin: 0; padding: 12px; color: #17202a; background: #ffffff; }
  h2 { margin: 0 0 6px 0; font-size: 16px; color: #111827; }
  .sub { font-size: 12px; color: #455468; margin-bottom: 10px; line-height: 1.35; overflow-wrap: anywhere; }
  .bar { display: flex; justify-content: space-between; align-items: center; gap: 8px; margin-bottom: 8px; }
  button { background: #0f62fe; border: 1px solid #0f62fe; color: #ffffff; padding: 6px 10px; border-radius: 4px; cursor: pointer; font-size: 12px; font-weight: 600; }
  button:hover { background: #0043ce; }
  .status { margin: 8px 0 10px 0; padding: 8px 10px; border-radius: 4px; font-size: 12px; line-height: 1.4; background: #eef5ff; color: #1f4e79; border: 1px solid #bfd7ff; white-space: pre-wrap; }
  .error { background: #fff1f1; color: #8a1f11; border: 1px solid #f5b8b3; }
  table { width: 100%; border-collapse: collapse; table-layout: fixed; margin-top: 8px; }
  th { background: #f2f4f8; color: #111827; font-size: 12px; font-weight: 700; text-align: left; padding: 7px; border: 1px solid #c8d0d9; }
  td { font-size: 12px; vertical-align: top; padding: 7px; border: 1px solid #c8d0d9; overflow-wrap: anywhere; word-wrap: break-word; }
  .num { width: 40px; text-align: right; color: #374151; }
  .id { width: 92px; font-weight: 600; color: #1f2937; }
  .title { font-weight: 700; color: #111827; margin-bottom: 4px; }
  .primary-text { color: #374151; line-height: 1.35; max-height: 8.2em; overflow: hidden; }
  a { color: #0f62fe; text-decoration: none; }
  a:hover { text-decoration: underline; }
  .footer { margin-top: 10px; font-size: 11px; color: #697386; line-height: 1.35; }
</style>
<script type="text/javascript">
(function () {
  "use strict";
  var prefs;
  function $(id) { return document.getElementById(id); }
  function adjustHeight() { try { if (gadgets && gadgets.window && gadgets.window.adjustHeight) { gadgets.window.adjustHeight(); } } catch (e) {} }
  function htmlEscape(value) { return String(value || "").replace(/[&<>\"']/g, function (c) { return { "&": "&amp;", "<": "&lt;", ">": "&gt;", "\"": "&quot;", "'": "&#39;" }[c]; }); }
  function stripTags(value) { var tmp = document.createElement("div"); tmp.innerHTML = value || ""; return (tmp.textContent || tmp.innerText || "").replace(/\s+/g, " ").trim(); }
  function setStatus(message, isError) { var el = $("status"); el.className = isError ? "status error" : "status"; el.textContent = message || ""; el.style.display = message ? "block" : "none"; adjustHeight(); }
  function getPref(name, fallback) { try { var value = prefs.getString(name); return value || fallback || ""; } catch (e) { return fallback || ""; } }

  function splitModuleAndConfig(rawUrl) {
    var result = { moduleUri: rawUrl, configUri: "" };
    var q = rawUrl.indexOf("?");
    if (q >= 0) {
      result.moduleUri = rawUrl.substring(0, q);
      var query = rawUrl.substring(q + 1).split("&");
      for (var i = 0; i < query.length; i++) {
        var pair = query[i].split("=");
        if (decodeURIComponent(pair[0]) === "oslc_config.context") {
          result.configUri = decodeURIComponent(pair.slice(1).join("="));
        }
      }
    }
    return result;
  }

  function withConfig(url, configUri) {
    if (!configUri) return url;
    if (url.indexOf("oslc_config.context=") >= 0) return url;
    return url + (url.indexOf("?") >= 0 ? "&" : "?") + "oslc_config.context=" + encodeURIComponent(configUri);
  }

  function requestText(url) {
    return new Promise(function (resolve, reject) {
      if (typeof gadgets === "undefined" || !gadgets.io || !gadgets.io.makeRequest) {
        reject(new Error("gadgets.io.makeRequest n'est pas disponible. Ce fichier doit etre execute comme widget OpenSocial dans DOORS Next."));
        return;
      }
      var params = {};
      params[gadgets.io.RequestParameters.METHOD] = gadgets.io.MethodType.GET;
      params[gadgets.io.RequestParameters.CONTENT_TYPE] = gadgets.io.ContentType.TEXT;
      params[gadgets.io.RequestParameters.HEADERS] = { "Accept": "application/rdf+xml, application/xml, text/xml, */*", "OSLC-Core-Version": "2.0" };
      try {
        if (gadgets.io.RequestParameters.AUTHORIZATION && gadgets.io.AuthorizationType && gadgets.io.AuthorizationType.SIGNED) {
          params[gadgets.io.RequestParameters.AUTHORIZATION] = gadgets.io.AuthorizationType.SIGNED;
        }
      } catch (e) {}
      gadgets.io.makeRequest(url, function (response) {
        if (response.errors && response.errors.length) { reject(new Error(response.errors.join("\n"))); return; }
        if (response.rc && response.rc >= 400) { reject(new Error("HTTP " + response.rc + " lors de l'appel : " + url)); return; }
        var text = response.text || response.data || "";
        if (!text) { reject(new Error("Reponse vide recue de DOORS Next pour : " + url)); return; }
        resolve(text);
      }, params);
    });
  }

  function parseXml(text) {
    var parser = new DOMParser();
    var xml = parser.parseFromString(text, "application/xml");
    if (xml.getElementsByTagName("parsererror").length > 0) { throw new Error("La reponse recue n'est pas un XML valide."); }
    return xml;
  }
  function localName(node) { return node ? (node.localName || node.nodeName.split(":").pop()) : ""; }
  function attrByLocalName(node, name) { if (!node || !node.attributes) return ""; for (var i = 0; i < node.attributes.length; i++) { if (localName(node.attributes[i]) === name) return node.attributes[i].value; } return ""; }
  function firstText(root, names) { var nodes = root.getElementsByTagName("*"); for (var i = 0; i < nodes.length; i++) { var ln = localName(nodes[i]); for (var j = 0; j < names.length; j++) { if (ln === names[j]) { var text = nodes[i].textContent || ""; if (text.trim()) return text.trim(); } } } return ""; }

  function collectRequirementUrisFromXml(xml, moduleUri) {
    var found = [];
    var nodes = xml.getElementsByTagName("*");
    for (var i = 0; i < nodes.length; i++) {
      var ln = localName(nodes[i]);
      var uri = "";
      if (ln === "uses" || ln === "about" || ln === "resource") { uri = attrByLocalName(nodes[i], "resource") || attrByLocalName(nodes[i], "about"); }
      if (!uri) { uri = attrByLocalName(nodes[i], "resourceURI") || attrByLocalName(nodes[i], "uri") || attrByLocalName(nodes[i], "url"); }
      if (uri && uri.indexOf("/rm/resources/") >= 0 && uri !== moduleUri && found.indexOf(uri) < 0) {
        if (uri.indexOf("/rm/resources/MD_") < 0) { found.push(uri); }
      }
    }
    return found;
  }

  function buildReportableModuleUrl(moduleUri, configUri) { var base = moduleUri.substring(0, moduleUri.indexOf("/resources/")); return withConfig(base + "/publish/modules?resourceURI=" + encodeURIComponent(moduleUri), configUri); }
  function buildDirectModuleUrl(moduleUri, configUri) { return withConfig(moduleUri, configUri); }

  function readRequirement(uri, configUri, index) {
    var url = withConfig(uri, configUri);
    return requestText(url).then(function (text) {
      var xml = parseXml(text);
      return { index: index + 1, uri: url, id: firstText(xml, ["identifier", "ID", "id"]), title: firstText(xml, ["title", "name", "label"]), text: firstText(xml, ["primaryText", "description", "text", "content"]) };
    }).catch(function (err) {
      return { index: index + 1, uri: url, id: "", title: "Lecture impossible", text: err.message };
    });
  }

  function render(items) {
    var tbody = $("rows");
    tbody.innerHTML = "";
    for (var i = 0; i < items.length; i++) {
      var it = items[i];
      var tr = document.createElement("tr");
      tr.innerHTML = "<td class='num'>" + it.index + "</td>" +
        "<td class='id'>" + htmlEscape(it.id || "-") + "</td>" +
        "<td><div class='title'><a target='_blank' rel='noopener noreferrer' href='" + htmlEscape(it.uri) + "'>" + htmlEscape(it.title || "Sans titre") + "</a></div>" +
        "<div class='primary-text'>" + htmlEscape(stripTags(it.text || "")) + "</div></td>";
      tbody.appendChild(tr);
    }
    $("table").style.display = items.length ? "table" : "none";
    adjustHeight();
  }

  function load() {
    prefs = new gadgets.Prefs();
    var rawUrl = getPref("moduleUrl", "").trim();
    var maxItems = parseInt(getPref("maxItems", "10"), 10);
    if (!maxItems || maxItems < 1) maxItems = 10;
    if (maxItems > 50) maxItems = 50;
    if (!rawUrl) { setStatus("L'URL directe du module n'est pas configuree.", true); return; }
    var parts = splitModuleAndConfig(rawUrl);
    $("moduleUri").textContent = parts.moduleUri;
    $("configUri").textContent = parts.configUri || "Non specifiee";
    $("table").style.display = "none";
    $("rows").innerHTML = "";
    setStatus("Chargement du module a partir de son URL directe...", false);
    var reportableUrl = buildReportableModuleUrl(parts.moduleUri, parts.configUri);
    var directUrl = buildDirectModuleUrl(parts.moduleUri, parts.configUri);

    requestText(reportableUrl)
      .then(function (text) { var xml = parseXml(text); var links = collectRequirementUrisFromXml(xml, parts.moduleUri); if (!links.length) throw new Error("Aucun lien d'exigence trouve via Reportable REST."); return links; })
      .catch(function () { return requestText(directUrl).then(function (text) { var xml = parseXml(text); var links = collectRequirementUrisFromXml(xml, parts.moduleUri); if (!links.length) throw new Error("Aucune exigence trouvee dans la representation directe du module."); return links; }); })
      .then(function (links) { links = links.slice(0, maxItems); setStatus("" + links.length + " exigence(s) trouvee(s). Chargement des details...", false); var promises = []; for (var i = 0; i < links.length; i++) { promises.push(readRequirement(links[i], parts.configUri, i)); } return Promise.all(promises); })
      .then(function (items) { render(items); setStatus("Affichage des " + items.length + " premiere(s) exigence(s) du module.", false); })
      .catch(function (err) {
        render([]);
        setStatus("Erreur lors du chargement du module.\n\n" + err.message + "\n\nA verifier :\n1. Le fichier XML du widget est heberge sur un domaine autorise/whiteliste dans JTS et RM.\n2. Ton utilisateur a acces au projet, au module et au stream configure.\n3. L'URL du module contient bien oslc_config.context.\n4. Si le serveur bloque Reportable REST pour les widgets, il faudra passer par un petit service intermediaire cote serveur.", true);
      });
  }
  window.onload = load;
  window.reloadDngModuleWidget = load;
}());
</script>
</head>
<body>
  <div class="bar">
    <div>
      <h2>10 premieres exigences du module</h2>
      <div class="sub"><strong>Module URI :</strong> <span id="moduleUri"></span></div>
      <div class="sub"><strong>Configuration :</strong> <span id="configUri"></span></div>
    </div>
    <button onclick="reloadDngModuleWidget()">Rafraichir</button>
  </div>
  <div id="status" class="status" style="display:none"></div>
  <table id="table" style="display:none">
    <thead><tr><th class="num">#</th><th class="id">ID</th><th>Exigence</th></tr></thead>
    <tbody id="rows"></tbody>
  </table>
  <div class="footer">Widget concu pour DOORS Next 7.0.3. Il utilise d'abord l'acces Reportable REST du module, puis tente une lecture directe RDF/XML du module si necessaire.</div>
</body>
</html>
  ]]></Content>
</Module>
