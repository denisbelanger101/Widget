<?xml version="1.0" encoding="UTF-8"?>
<!--
  DOORS Next / RM OpenSocial Gadget
  File name suggestion in repo: user-time-spent-today.xml
  Purpose: Tracks the current user's active time spent in DOORS Next for the current local day.

  Important limitation:
  - This widget measures only the current browser/user session where the widget is loaded.
  - It does not provide authoritative server-side time for all users.
  - For all-user reporting, a server-side log/audit aggregation service is required.

  Deployment options:
  1) Host this XML file in your DNG widget extensions web location.
  2) Add it as an OpenSocial Gadget by URL, or reference it from WidgetCatalog.xml.
-->
<Module>
  <ModulePrefs
      title="DOORS Next - Time Spent Today"
      description="Tracks the current user's active time spent in DOORS Next during the current local day."
      author="Denis Belanger / Microsoft Copilot"
      height="390"
      scrolling="true">
    <Require feature="dynamic-height" />
    <Require feature="settitle" />
  </ModulePrefs>

  <Content type="html"><![CDATA[
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8" />
<style>
  body {
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
    padding: 12px;
    color: #1f2933;
    background: #ffffff;
  }
  .card {
    border: 1px solid #d9e2ec;
    border-radius: 8px;
    padding: 12px;
    background: #f8fafc;
  }
  h2 {
    margin: 0 0 8px 0;
    font-size: 16px;
    color: #102a43;
  }
  .metric {
    font-size: 30px;
    font-weight: bold;
    color: #005ea8;
    margin: 10px 0 4px 0;
  }
  .label {
    font-size: 12px;
    color: #52616b;
  }
  .row {
    margin-top: 10px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  button {
    border: 1px solid #005ea8;
    background: #005ea8;
    color: #ffffff;
    border-radius: 5px;
    padding: 6px 10px;
    cursor: pointer;
    font-size: 12px;
  }
  button.secondary {
    background: #ffffff;
    color: #005ea8;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 12px;
    font-size: 12px;
  }
  th, td {
    border-bottom: 1px solid #d9e2ec;
    text-align: left;
    padding: 6px;
  }
  th {
    background: #eef2f7;
    color: #243b53;
  }
  .status-active { color: #00875a; font-weight: bold; }
  .status-idle { color: #bf2600; font-weight: bold; }
  .note {
    margin-top: 10px;
    font-size: 11px;
    color: #627d98;
    line-height: 1.35;
  }
</style>
</head>
<body>
  <div class="card">
    <h2>DOORS Next - Time Spent Today</h2>
    <div class="label">Current user, current browser, local day</div>
    <div id="timeMetric" class="metric">00:00:00</div>
    <div id="status" class="label">Status: calculating...</div>

    <table>
      <tbody>
        <tr><th>Date</th><td id="todayCell"></td></tr>
        <tr><th>Session started</th><td id="sessionStartCell"></td></tr>
        <tr><th>Last activity</th><td id="lastActivityCell"></td></tr>
        <tr><th>Idle threshold</th><td>2 minutes</td></tr>
      </tbody>
    </table>

    <div class="row">
      <button onclick="resetToday()">Reset today</button>
      <button class="secondary" onclick="exportCsv()">Export CSV</button>
    </div>

    <div class="note">
      This widget estimates active time only while it is loaded in the user's browser.
      It pauses counting when the tab/window is hidden or when no mouse/keyboard activity is detected for more than 2 minutes.
      It is not an authoritative all-user audit report.
    </div>
  </div>

<script type="text/javascript">
(function () {
  var IDLE_LIMIT_MS = 2 * 60 * 1000;
  var TICK_MS = 1000;
  var startedAt = new Date();
  var lastActivity = new Date();
  var lastTick = new Date();

  function yyyyMmDd(d) {
    var yyyy = d.getFullYear();
    var mm = String(d.getMonth() + 1).padStart(2, '0');
    var dd = String(d.getDate()).padStart(2, '0');
    return yyyy + '-' + mm + '-' + dd;
  }

  function storageKey() {
    return 'dngTimeSpentToday:' + yyyyMmDd(new Date());
  }

  function readSeconds() {
    var raw = window.localStorage.getItem(storageKey());
    var value = parseInt(raw || '0', 10);
    return isNaN(value) ? 0 : value;
  }

  function writeSeconds(seconds) {
    window.localStorage.setItem(storageKey(), String(Math.max(0, Math.floor(seconds))));
  }

  function isActiveNow() {
    var now = new Date();
    var recentlyActive = (now.getTime() - lastActivity.getTime()) <= IDLE_LIMIT_MS;
    var visible = document.visibilityState !== 'hidden';
    return recentlyActive && visible;
  }

  function formatDuration(totalSeconds) {
    totalSeconds = Math.max(0, Math.floor(totalSeconds));
    var h = Math.floor(totalSeconds / 3600);
    var m = Math.floor((totalSeconds % 3600) / 60);
    var s = totalSeconds % 60;
    return String(h).padStart(2, '0') + ':' +
           String(m).padStart(2, '0') + ':' +
           String(s).padStart(2, '0');
  }

  function setText(id, value) {
    var el = document.getElementById(id);
    if (el) { el.textContent = value; }
  }

  function refreshUi() {
    var seconds = readSeconds();
    setText('timeMetric', formatDuration(seconds));
    setText('todayCell', yyyyMmDd(new Date()));
    setText('sessionStartCell', startedAt.toLocaleString());
    setText('lastActivityCell', lastActivity.toLocaleString());

    var active = isActiveNow();
    var status = document.getElementById('status');
    if (status) {
      status.innerHTML = 'Status: <span class="' + (active ? 'status-active' : 'status-idle') + '">' +
                         (active ? 'Active - counting time' : 'Idle/hidden - paused') + '</span>';
    }

    if (typeof gadgets !== 'undefined' && gadgets.window && gadgets.window.adjustHeight) {
      gadgets.window.adjustHeight();
    }
  }

  function activity() {
    lastActivity = new Date();
    refreshUi();
  }

  function tick() {
    var now = new Date();
    var deltaSeconds = Math.round((now.getTime() - lastTick.getTime()) / 1000);
    lastTick = now;

    if (isActiveNow()) {
      writeSeconds(readSeconds() + deltaSeconds);
    }
    refreshUi();
  }

  window.resetToday = function () {
    writeSeconds(0);
    activity();
  };

  window.exportCsv = function () {
    var date = yyyyMmDd(new Date());
    var seconds = readSeconds();
    var csv = 'date,user_scope,seconds,time_hh_mm_ss,session_started,last_activity\n' +
              date + ',current-browser-user,' + seconds + ',' + formatDuration(seconds) + ',' +
              '"' + startedAt.toISOString() + '","' + lastActivity.toISOString() + '"\n';
    var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'doors-next-time-spent-' + date + '.csv';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  };

  ['mousemove', 'mousedown', 'keydown', 'scroll', 'touchstart', 'click'].forEach(function (eventName) {
    document.addEventListener(eventName, activity, true);
  });
  document.addEventListener('visibilitychange', function () {
    lastTick = new Date();
    activity();
  });

  if (typeof gadgets !== 'undefined' && gadgets.window && gadgets.window.setTitle) {
    gadgets.window.setTitle('DOORS Next - Time Spent Today');
  }

  activity();
  setInterval(tick, TICK_MS);
})();
</script>
</body>
</html>
  ]]></Content>
</Module>
